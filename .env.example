# AumOS Text Engine — Environment Variables
# Copy this file to .env and fill in your local values.
# Never commit .env to version control.

# -----------------------------------------------------------------------
# Core AumOS settings (aumos-common.config.AumOSSettings)
# -----------------------------------------------------------------------
AUMOS_SERVICE_NAME=aumos-text-engine
AUMOS_ENVIRONMENT=development
AUMOS_DEBUG=true

# PostgreSQL (asyncpg)
AUMOS_DATABASE__URL=postgresql+asyncpg://aumos:aumos_dev@localhost:5432/aumos
AUMOS_DATABASE__POOL_SIZE=10
AUMOS_DATABASE__MAX_OVERFLOW=5

# Kafka
AUMOS_KAFKA__BROKERS=localhost:9092

# Redis
AUMOS_REDIS__URL=redis://localhost:6379/0

# MinIO (S3-compatible object storage)
AUMOS_MINIO__ENDPOINT=localhost:9000
AUMOS_MINIO__ACCESS_KEY=minioadmin
AUMOS_MINIO__SECRET_KEY=minioadmin
AUMOS_MINIO__SECURE=false
AUMOS_MINIO__BUCKET=aumos-text-engine

# Observability
AUMOS_OTEL_ENDPOINT=http://localhost:4317
AUMOS_LOG_LEVEL=DEBUG

# -----------------------------------------------------------------------
# Text Engine specific (env prefix: AUMOS_TEXT_)
# -----------------------------------------------------------------------

# LLM serving (aumos-llm-serving / vLLM / Ollama)
AUMOS_TEXT__LLM_SERVING_URL=http://localhost:8001
AUMOS_TEXT__LLM_SERVING_TIMEOUT_SECONDS=120
AUMOS_TEXT__DEFAULT_MODEL=llama3-8b-instruct
AUMOS_TEXT__MAX_TOKENS=4096
AUMOS_TEXT__TEMPERATURE=0.7

# Privacy Engine (aumos-privacy-engine) for DP budget
AUMOS_TEXT__PRIVACY_ENGINE_URL=http://localhost:8002
AUMOS_TEXT__PRIVACY_ENGINE_TIMEOUT_SECONDS=30

# PII detection
AUMOS_TEXT__SPACY_MODEL=en_core_web_lg
AUMOS_TEXT__PRESIDIO_SCORE_THRESHOLD=0.7
AUMOS_TEXT__PII_REPLACEMENT_STRATEGY=entity_aware

# Quality validation
AUMOS_TEXT__SEMANTIC_SIMILARITY_THRESHOLD=0.7
AUMOS_TEXT__EMBEDDING_MODEL=all-MiniLM-L6-v2

# Batch processing
AUMOS_TEXT__BATCH_MAX_DOCUMENTS=100
AUMOS_TEXT__BATCH_CONCURRENCY=5

# Fine-tuning (LoRA)
AUMOS_TEXT__FINETUNE_OUTPUT_DIR=/tmp/aumos-text-engine/models
AUMOS_TEXT__FINETUNE_MAX_STEPS=1000
AUMOS_TEXT__FINETUNE_LEARNING_RATE=3e-4
